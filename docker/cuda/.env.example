# ── 运行模式 ──
IS_DEV=false

# ── 检测模块 ──────────────────────────────────────
YOLO_MODEL_PATH=/app/models/v1.pt
YOLO_CONF_THRESHOLD=0.4
YOLO_DEVICE=cuda

# ── 数据库 ──────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=test

# ── 对象存储 (S3 兼容) ─────────────────────────────
S3_SERVER=localhost
S3_PORT=9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET_NAME=traffic
S3_PUBLIC_ENDPOINT=
S3_PRESIGNED_EXPIRES=600
